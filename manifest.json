{
  "manifest_version": 3,
  "name": "NotebookLM Quick Capture",
  "version": "0.3.2",
  "description": "Save pages, selections, and pasted text into a NotebookLM notebook.",
  "permissions": ["scripting", "storage", "tabs", "sidePanel", "contextMenus"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "action": {
    "default_title": "NotebookLM Quick Capture",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "exclude_matches": ["https://notebooklm.google.com/*"],
      "js": [
        "src/lib/extractor.js",
        "src/shared/clipModels.js",
        "src/adapters/base/adapterRegistry.js",
        "src/adapters/web/webAdapter.js",
        "src/content/page-content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
